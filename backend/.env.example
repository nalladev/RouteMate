# Server Configuration
PORT=3000
SERVER_URL=https://routemate-jpsc.onrender.com/health

# Firebase Configuration
# Base64 encoded Firebase service account key
# Generate at: https://console.firebase.google.com/project/YOUR_PROJECT/settings/serviceaccounts/adminsdk
GOOGLE_APPLICATION_CREDENTIALS=<base64_encoded_firebase_key>

# JWT Secret for backend token generation
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# Telegram Chat ID where error logs will be sent
# Create a group/channel, add the bot, and get the chat ID
TELEGRAM_CHAT_ID=<your_telegram_chat_id>

# Optional: Enable storing error logs in Firestore
STORE_ERROR_LOGS=false

# Node Environment
NODE_ENV=development
